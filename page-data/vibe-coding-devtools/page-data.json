matter":{"title":"바이브 코딩으로 개발자 도구 사이트를 만들었다 — 비개발자도 할 수 있다","emoji":"🎵"}}},{"node":{"id":"59cd0113-290f-5759-9820-ab7ec2aaf02a","fields":{"slug":"/vibe-coding-flutter-driver-test/"},"frontmatter":{"title":"코딩 한 글자 없이 Flutter 앱 만들기 (feat. 운전면허 필기시험 모의고사)","emoji":"🚗"}}}]},"previous":{"fields":{"slug":"/remote-dev-tailscale-mosh-tmux-happy/"},"frontmatter":{"title":"아이패드(혹은 스마트폰)로 원격 개발하기 — Tailscale + Mosh + Tmux + Happy Coder"}},"next":{"fields":{"slug":"/vibe-coding-flutter-driver-test/"},"frontmatter":{"title":"코딩 한 글자 없이 Flutter 앱 만들기 (feat. 운전면허 필기시험 모의고사)","emoji":"🚗"}}},"pageContext":{"id":"567855a4-1bd4-5d5f-9f51-3995a74f66da","series":null,"previousPostId":"ace4c267-7850-5671-b3f3-cfc9ba089d64","nextPostId":"59cd0113-290f-5759-9820-ab7ec2aaf02a"}},"staticQueryHashes":[],"slicesMap":{}}